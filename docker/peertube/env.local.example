# Optional root .env additions/overrides for the OLT local PeerTube service.
# The root .env already contains generated runnable values.

PEERTUBE_WEBSERVER_HOSTNAME=peertube.localhost
PEERTUBE_WEBSERVER_PORT=80
PEERTUBE_WEBSERVER_HTTPS=false
PEERTUBE_TRUST_PROXY=["loopback","linklocal","uniquelocal","172.16.0.0/12"]

PEERTUBE_DB_HOSTNAME=postgres
PEERTUBE_DB_PORT=5432
PEERTUBE_DB_NAME=olt_peertube
PEERTUBE_DB_USERNAME=olt
PEERTUBE_DB_PASSWORD=example-local-postgres-password
PEERTUBE_DB_SSL=false

PEERTUBE_REDIS_HOSTNAME=redis
PEERTUBE_REDIS_PORT=6379

PEERTUBE_SECRET=example-local-peertube-secret
PEERTUBE_ADMIN_EMAIL=admin@olt.localhost

PEERTUBE_SMTP_HOSTNAME=maildev
PEERTUBE_SMTP_PORT=1025
PEERTUBE_SMTP_TLS=false
PEERTUBE_SMTP_DISABLE_STARTTLS=true
PEERTUBE_SMTP_FROM=noreply@olt.localhost

PEERTUBE_INSTANCE_NAME=OLT Videos
PEERTUBE_INSTANCE_SHORT_DESCRIPTION=Local OLT video service for development.
PEERTUBE_SIGNUP_ENABLED=false
PEERTUBE_CONTACT_FORM_ENABLED=false
PEERTUBE_REDIRECT_ON_SINGLE_EXTERNAL_AUTH=true

# OIDC plugin/client settings.
PEERTUBE_OIDC_ISSUER=http://olt.localhost
PEERTUBE_OIDC_CLIENT_ID=peertube-local
PEERTUBE_OIDC_CLIENT_SECRET=example-local-peertube-client-secret
PEERTUBE_OIDC_PLUGIN_VERSION=1.1.0
PEERTUBE_OIDC_SCOPE=openid profile email

# OLT xAPI plugin settings. These are endpoint URLs only, not credentials.
OLT_XAPI_INTERNAL_INGEST_URL=http://ralph:8100/xAPI/statements
OLT_XAPI_PUBLIC_INGEST_URL=http://lrs.localhost/xAPI/statements
OLT_XAPI_ACTIVITY_PREFIX=http://olt.localhost/xapi
PEERTUBE_OLT_XAPI_ENABLED=true
PEERTUBE_OLT_XAPI_PLUGIN_VERSION=0.1.0
PEERTUBE_OLT_XAPI_PLUGIN_SOURCE=/bootstrap/plugins/peertube-plugin-olt-xapi
