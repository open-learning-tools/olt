# Example-only values. The runnable local stack uses the generated `.env`.

NGINX_HTTP_PORT=80

TZ=America/New_York
PUID=1000
PGID=1000

POSTGRES_USER=olt
POSTGRES_PASSWORD=example-local-postgres-password
POSTGRES_DB=olt
POSTGRES_MULTIPLE_DATABASES=olt_django,olt_peertube

DJANGO_DEBUG=1
DJANGO_SECRET_KEY=example-local-django-secret-key
ALLOWED_HOSTS=olt.localhost,auth.localhost,backend,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=olt.localhost,auth.localhost,backend,localhost,127.0.0.1
DJANGO_DB_NAME=olt_django
DJANGO_DB_USER=olt
DJANGO_DB_PASSWORD=example-local-postgres-password
DJANGO_SUPERUSER_USERNAME=gabe
DJANGO_SUPERUSER_EMAIL=gabe@olt.localhost
DJANGO_SUPERUSER_PASSWORD=example-local-admin-password
OIDC_ISSUER_URL=http://olt.localhost
OIDC_AUTHORIZE_URL=http://olt.localhost/o/authorize/
OIDC_TOKEN_URL=http://olt.localhost/o/token/
OIDC_JWKS_URL=http://olt.localhost/o/.well-known/jwks.json
OIDC_RSA_PRIVATE_KEY_FILE=/run/secrets/olt_oidc_private_key
HEADLESS_JWT_PRIVATE_KEY_FILE=/run/secrets/olt_oidc_private_key
HEADLESS_JWT_ISSUER=http://olt.localhost
HEADLESS_JWT_AUDIENCE=open-learning-tools
RESEND_API_KEY=local-dev-unused

PEERTUBE_OIDC_CLIENT_ID=peertube-local
PEERTUBE_OIDC_CLIENT_SECRET=example-local-peertube-client-secret
PEERTUBE_OIDC_PLUGIN_VERSION=1.1.0
PEERTUBE_OIDC_SCOPE=openid email profile
LIBRECHAT_OIDC_CLIENT_ID=librechat-local
LIBRECHAT_OIDC_CLIENT_SECRET=example-local-librechat-client-secret
LIBRECHAT_OIDC_CALLBACK_PATH=/oauth/openid/callback
LIBRECHAT_OIDC_SCOPE=openid profile email
CRYPTPAD_OAUTH_CLIENT_ID=cryptpad-proxy-local
CRYPTPAD_OAUTH_CLIENT_SECRET=example-local-docs-client-secret
CRYPTPAD_OAUTH_COOKIE_SECRET=00112233445566778899aabbccddeeff
SCHOLARSOME_OAUTH_CLIENT_ID=scholarsome-proxy-local
SCHOLARSOME_OAUTH_CLIENT_SECRET=example-local-flashcards-client-secret
SCHOLARSOME_OAUTH_COOKIE_SECRET=0123456789abcdef0123456789abcdef
CODE_OAUTH_CLIENT_ID=code-proxy-local
CODE_OAUTH_CLIENT_SECRET=example-local-code-client-secret
CODE_OAUTH_COOKIE_SECRET=abcdef0123456789abcdef0123456789

PEERTUBE_DB_NAME=olt_peertube
PEERTUBE_DB_USER=olt
PEERTUBE_DB_PASSWORD=example-local-postgres-password
PEERTUBE_SECRET=example-local-peertube-secret
PEERTUBE_ADMIN_EMAIL=admin@olt.localhost
PEERTUBE_SMTP_FROM=noreply@olt.localhost
PEERTUBE_REDIRECT_ON_SINGLE_EXTERNAL_AUTH=true

SCHOLARSOME_DB_PASSWORD=example-local-flashcards-db-password
SCHOLARSOME_JWT_SECRET=example-local-flashcards-jwt-secret

CODE_SERVER_PASSWORD=local-code-password
CODE_SERVER_SUDO_PASSWORD=local-code-sudo-password

LIBRECHAT_MONGO_DB=LibreChat
LIBRECHAT_JWT_SECRET=example-local-librechat-jwt-secret
LIBRECHAT_JWT_REFRESH_SECRET=example-local-librechat-refresh-secret
LIBRECHAT_CREDS_KEY=examplelocalcredskey000000000000000000000000000000
LIBRECHAT_CREDS_IV=examplelocalcredsiv
LIBRECHAT_ALLOW_SOCIAL_LOGIN=true
LIBRECHAT_OPENID_SESSION_SECRET=example-local-librechat-openid-session-secret
LIBRECHAT_ALLOW_EMAIL_LOGIN=false
LIBRECHAT_ALLOW_REGISTRATION=false
LIBRECHAT_ENDPOINTS=openAI,agents
LIBRECHAT_PROVIDER_ENV_FILE=./.librechat-provider.env

RALPH_MONGO_DB=ralph
RALPH_LRS_USERNAME=admin
RALPH_LRS_EMAIL=admin@example.com
RALPH_LRS_PASSWORD=example-local-ralph-password

SMTP_HOSTNAME=maildev
SMTP_PORT=1025
