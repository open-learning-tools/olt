{
  "//": "OLT-branded VS Code workbench theme for code-server. Colors map to the OLT palette (cream + navy + turquoise) used by the OLT wrapper landing page (web/src/App.css) and olt.academy. Editor body keeps a clean white surface so source code stays readable; OLT colors are applied to the VS Code chrome (title bar, activity bar, side bar, status bar, tabs, panel).",

  "workbench.colorTheme": "Default Light Modern",
  "workbench.iconTheme": "vs-seti",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 14,
  "window.titleBarStyle": "custom",
  "window.title": "OLT Code  ${separator}  ${activeEditorShort}${separator}${rootName}",

  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.lineHeight": 1.55,
  "editor.cursorBlinking": "smooth",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",

  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,

  "workbench.colorCustomizations": {
    "// --- OLT brand tokens ---": "cream #F8F8F4, navy #1F2A55, navy-deep #161E3D, navy-soft #5C6478, turquoise #4FBED1, hairline #D8D5CC",

    "// title bar": "OLT navy chrome with cream text",
    "titleBar.activeBackground": "#1F2A55",
    "titleBar.activeForeground": "#F8F8F4",
    "titleBar.inactiveBackground": "#161E3D",
    "titleBar.inactiveForeground": "#D8D5CC",
    "titleBar.border": "#161E3D",

    "// menu bar (inside title bar)": "",
    "menubar.selectionBackground": "#4FBED133",
    "menubar.selectionForeground": "#F8F8F4",
    "menu.background": "#1F2A55",
    "menu.foreground": "#F8F8F4",
    "menu.selectionBackground": "#4FBED1",
    "menu.selectionForeground": "#1F2A55",
    "menu.separatorBackground": "#5C6478",

    "// activity bar (left rail)": "navy with turquoise accent",
    "activityBar.background": "#161E3D",
    "activityBar.foreground": "#F8F8F4",
    "activityBar.inactiveForeground": "#D8D5CCAA",
    "activityBar.border": "#1F2A55",
    "activityBar.activeBorder": "#4FBED1",
    "activityBar.activeBackground": "#1F2A55",
    "activityBarBadge.background": "#4FBED1",
    "activityBarBadge.foreground": "#1F2A55",

    "// side bar (file explorer, etc.)": "cream surface for warmth",
    "sideBar.background": "#F8F8F4",
    "sideBar.foreground": "#1F2A55",
    "sideBar.border": "#D8D5CC",
    "sideBarTitle.foreground": "#1F2A55",
    "sideBarSectionHeader.background": "#F0EEE6",
    "sideBarSectionHeader.foreground": "#1F2A55",
    "sideBarSectionHeader.border": "#D8D5CC",

    "// list selection inside side bar / explorer": "",
    "list.activeSelectionBackground": "#1F2A55",
    "list.activeSelectionForeground": "#F8F8F4",
    "list.inactiveSelectionBackground": "#E6E2D6",
    "list.inactiveSelectionForeground": "#1F2A55",
    "list.hoverBackground": "#EDEAE0",
    "list.hoverForeground": "#1F2A55",
    "list.focusBackground": "#E6E2D6",
    "list.focusForeground": "#1F2A55",
    "list.highlightForeground": "#4FBED1",

    "// editor groups + tabs": "white editor on cream chrome",
    "editorGroupHeader.tabsBackground": "#F0EEE6",
    "editorGroupHeader.tabsBorder": "#D8D5CC",
    "editorGroupHeader.border": "#D8D5CC",
    "editorGroup.border": "#D8D5CC",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#1F2A55",
    "tab.activeBorderTop": "#4FBED1",
    "tab.activeBorder": "#FFFFFF",
    "tab.inactiveBackground": "#F0EEE6",
    "tab.inactiveForeground": "#5C6478",
    "tab.hoverBackground": "#F8F8F4",
    "tab.hoverForeground": "#1F2A55",
    "tab.border": "#D8D5CC",
    "tab.unfocusedActiveBorderTop": "#5C6478",

    "// editor itself": "keep clean white for code legibility",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#1F2A55",
    "editorLineNumber.foreground": "#B6B2A4",
    "editorLineNumber.activeForeground": "#1F2A55",
    "editorCursor.foreground": "#4FBED1",
    "editor.selectionBackground": "#4FBED14D",
    "editor.selectionHighlightBackground": "#4FBED126",
    "editor.findMatchBackground": "#4FBED180",
    "editor.findMatchHighlightBackground": "#4FBED13D",
    "editor.lineHighlightBackground": "#F8F8F4",
    "editor.lineHighlightBorder": "#F8F8F400",
    "editorIndentGuide.background1": "#EDEAE0",
    "editorIndentGuide.activeBackground1": "#4FBED1",
    "editorBracketMatch.background": "#4FBED126",
    "editorBracketMatch.border": "#4FBED1",
    "editorWhitespace.foreground": "#D8D5CC",
    "editorRuler.foreground": "#EDEAE0",

    "// status bar": "OLT navy with turquoise focus state",
    "statusBar.background": "#1F2A55",
    "statusBar.foreground": "#F8F8F4",
    "statusBar.border": "#161E3D",
    "statusBar.noFolderBackground": "#161E3D",
    "statusBar.debuggingBackground": "#4FBED1",
    "statusBar.debuggingForeground": "#1F2A55",
    "statusBarItem.hoverBackground": "#4FBED133",
    "statusBarItem.remoteBackground": "#4FBED1",
    "statusBarItem.remoteForeground": "#1F2A55",
    "statusBarItem.prominentBackground": "#4FBED1",
    "statusBarItem.prominentForeground": "#1F2A55",
    "statusBarItem.prominentHoverBackground": "#74CDDC",

    "// panel (terminal, problems, output)": "",
    "panel.background": "#F8F8F4",
    "panel.border": "#D8D5CC",
    "panelTitle.activeForeground": "#1F2A55",
    "panelTitle.activeBorder": "#4FBED1",
    "panelTitle.inactiveForeground": "#5C6478",
    "panelSectionHeader.background": "#F0EEE6",
    "panelSectionHeader.foreground": "#1F2A55",

    "// terminal palette": "soft on cream",
    "terminal.background": "#F8F8F4",
    "terminal.foreground": "#1F2A55",
    "terminal.selectionBackground": "#4FBED14D",
    "terminalCursor.foreground": "#4FBED1",

    "// inputs, dropdowns, badges": "",
    "input.background": "#FFFFFF",
    "input.foreground": "#1F2A55",
    "input.border": "#D8D5CC",
    "input.placeholderForeground": "#5C6478",
    "inputOption.activeBackground": "#4FBED133",
    "inputOption.activeBorder": "#4FBED1",
    "inputOption.activeForeground": "#1F2A55",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#1F2A55",
    "dropdown.border": "#D8D5CC",
    "badge.background": "#4FBED1",
    "badge.foreground": "#1F2A55",

    "// buttons + focus": "OLT navy primary, turquoise focus ring",
    "button.background": "#1F2A55",
    "button.foreground": "#F8F8F4",
    "button.hoverBackground": "#2A3766",
    "button.secondaryBackground": "#F0EEE6",
    "button.secondaryForeground": "#1F2A55",
    "button.secondaryHoverBackground": "#E6E2D6",
    "focusBorder": "#4FBED1",
    "contrastBorder": "#D8D5CC",

    "// quick input / command palette": "",
    "quickInput.background": "#FFFFFF",
    "quickInput.foreground": "#1F2A55",
    "quickInputTitle.background": "#F8F8F4",

    "// notifications": "",
    "notifications.background": "#1F2A55",
    "notifications.foreground": "#F8F8F4",
    "notifications.border": "#161E3D",
    "notificationCenterHeader.background": "#161E3D",
    "notificationCenterHeader.foreground": "#F8F8F4",
    "notificationLink.foreground": "#4FBED1",

    "// scrollbars": "",
    "scrollbarSlider.background": "#5C647833",
    "scrollbarSlider.hoverBackground": "#5C647855",
    "scrollbarSlider.activeBackground": "#1F2A5588",

    "// breadcrumbs": "",
    "breadcrumb.background": "#FFFFFF",
    "breadcrumb.foreground": "#5C6478",
    "breadcrumb.focusForeground": "#1F2A55",
    "breadcrumb.activeSelectionForeground": "#1F2A55",

    "// links": "",
    "textLink.foreground": "#4FBED1",
    "textLink.activeForeground": "#1F2A55"
  }
}
