# OLT local-development Scholarsome environment.
# Keep real secrets in the root .env file or an untracked local override.

NODE_ENV=development
HTTP_PORT=3000
HOST=scholarsome.localhost

# Upstream Scholarsome Docker docs currently describe a MySQL/MariaDB URL.
# The parent OLT stack may override this with its shared database choice.
DATABASE_URL=

# Required by upstream Scholarsome, but intentionally blank here.
JWT_SECRET=

# Redis is provided by the parent OLT stack.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Local media storage for development. Mount this path from the parent Compose
# service before enabling uploads.
STORAGE_TYPE=local
STORAGE_LOCAL_DIR=/data

# Optional local development integrations.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
S3_STORAGE_ENDPOINT=
S3_STORAGE_ACCESS_KEY=
S3_STORAGE_SECRET_KEY=
S3_STORAGE_REGION=
S3_STORAGE_BUCKET=
SCHOLARSOME_RECAPTCHA_SITE=
SCHOLARSOME_RECAPTCHA_SECRET=
SCHOLARSOME_HEAD_SCRIPTS_BASE64=

# OLT xAPI local-dev forwarding. The public URL is safe for browser-visible
# instrumentation; do not embed Ralph Basic Auth credentials here.
OLT_XAPI_INTERNAL_INGEST_URL=
OLT_XAPI_PUBLIC_INGEST_URL=
OLT_XAPI_ACTIVITY_PREFIX=

# TLS should stay disabled for this local HTTP-only stack.
SSL_KEY_BASE64=
SSL_CERT_BASE64=
